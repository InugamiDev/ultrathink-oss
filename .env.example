# ── Required ──────────────────────────────────────────────
# Neon Postgres connection string (with pgvector + pg_trgm enabled)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ── Optional: Embeddings ──────────────────────────────────
# Set to enable vector similarity search (semantic search)
# Works with any OpenAI-compatible embedding API
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_API_URL=https://api.openai.com/v1/embeddings

# ── Optional: Dashboard ───────────────────────────────────
# NEXT_PUBLIC_APP_URL=http://localhost:3333
# PORT=3333

# ── Optional: Discord Notifications ──────────────────────
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── Optional: Voice ──────────────────────────────────────
# Uses macOS native `say` command — no API key needed
# VOICE_ENABLED=true
