# UltraThink Environment Variables
# Copy to .env and fill in your values

# Core
DATABASE_URL=postgresql://user:password@your-host.neon.tech/neondb?sslmode=require
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url

# Dashboard
DASHBOARD_SECRET=your-dashboard-secret-here
NEXT_PUBLIC_APP_URL=http://localhost:3333
PORT=3333

# Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=

# Memory (optional - pgvector embedding provider)
OPENAI_API_KEY=

# Groq AI (for dashboard AI chat)
GROQ_API_KEY=your-groq-api-key

# Agora Voice AI
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-app-certificate
AGORA_CUSTOMER_ID=your-agora-customer-id
AGORA_CUSTOMER_SECRET=your-agora-customer-secret
AGORA_AGENT_UID=1000
AGORA_CONVO_AI_BASE_URL=https://api.agora.io/api/conversational-ai-agent/v2/projects

# Agora LLM
AGORA_LLM_URL=https://api.openai.com/v1
AGORA_LLM_API_KEY=your-llm-api-key
AGORA_LLM_MODEL=gpt-4o

# Agora TTS (choose one: elevenlabs or microsoft)
AGORA_TTS_VENDOR=elevenlabs
AGORA_ELEVENLABS_API_KEY=your-elevenlabs-key
AGORA_MICROSOFT_TTS_KEY=your-microsoft-tts-key
AGORA_MICROSOFT_TTS_REGION=eastus
