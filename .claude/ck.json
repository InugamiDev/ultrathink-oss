{
  "project": "ultrathink",
  "version": "1.0.0",
  "defaultLanguage": "en",
  "codingLevel": "practical-builder",
  "outputFormat": "markdown",
  "defaultPlanDir": ".planning",
  "archiveDir": ".planning/archive",
  "journalDir": ".planning/docs",
  "dashboard": {
    "port": 3333
  },
  "statusline": {
    "showMode": true,
    "showMemory": true,
    "showContext": true
  },
  "memory": {
    "provider": "neon",
    "autoRecall": true,
    "writePolicy": "selective",
    "compactionThreshold": 100
  },
  "privacyHook": {
    "enabled": true,
    "sensitivityLevel": "standard",
    "logEvents": true
  },
  "notifications": {
    "telegram": null,
    "discord": null,
    "slack": null
  },
  "kanban": {
    "defaultBoard": "main"
  },
  "uiTest": {
    "viewports": ["375x667", "768x1024", "1440x900"],
    "reportDir": "./reports/ui-tests"
  },
  "reports": {
    "outputDir": "./reports"
  }
}
